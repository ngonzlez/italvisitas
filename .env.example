# Supabase — Get from: https://supabase.com/dashboard/project/_/settings/database
# Use the "Pooler" connection string for DATABASE_URL (port 6543)
# Use the "Direct" connection string for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase — Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Supabase Storage bucket name (create manually in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="visit-photos"
